# ── OpenRouter (required) ─────────────────────────────────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Model served via OpenRouter — use the anthropic/ prefix
# anthropic/claude-haiku-4-5   cheapest
# anthropic/claude-sonnet-4-5  best value for forecasting (default)
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5

# ── Web Search (recommended) ──────────────────────────────────────────────
# Get a free key at https://tavily.com  (1,000 searches/month free)
TAVILY_API_KEY=tvly-your_key_here

# ── Prophet Arena ─────────────────────────────────────────────────────────
# Get your key at https://prophetarena.co/profile/api-keys
PA_SERVER_API_KEY=prophet_your_key_here
PA_SERVER_URL=https://api.aiprophet.dev

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000
